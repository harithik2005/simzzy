# Normalize line endings: store text as LF in the repo, check out native.
* text=auto

# Explicit text types (kept LF in the repo)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.prisma text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never normalize/diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.xlsx  binary
*.woff  binary
*.woff2 binary
