# Simzzy frontend (Next.js app) — environment template.
# Copy to `.env.local` and fill in. NEVER commit real values.
# Variable NAMES must match exactly — the app reads these at runtime.

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Same connection strings as simzzy-backend. URL-encode reserved chars in the
# password (e.g. % -> %25, + -> %2B, @ -> %40).
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:<URL_ENCODED_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# ── Auth (NextAuth / Auth.js v5) ──────────────────────────────────────────────
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 32`).
AUTH_SECRET="<RANDOM_SECRET>"
# AUTH_TRUST_HOST: set "true" when deploying behind a proxy (Vercel/Railway).
AUTH_TRUST_HOST="true"

# ── Payments ──────────────────────────────────────────────────────────────────
# Active payment gateway. "fake" runs the sandbox FakePaymentProvider (validates
# a single test card, no real charge); "cashfree" is reserved for the future PSP.
PAYMENT_PROVIDER="fake"
# Public mirror (NEXT_PUBLIC_*) so the checkout UI shows the TEST MODE badge and
# the collapsible test-card panel. Keep in sync with PAYMENT_PROVIDER.
NEXT_PUBLIC_PAYMENT_PROVIDER="fake"

# ── tSIM (TSim Tech) eSIM supplier — optional/future (Phase 4H) ───────────────
# Only needed once provider calls are wired into the app. Read-only verification
# today runs from simzzy-backend. See simzzy-backend/.env.example for details.
# TSIM_API_HOST="https://api.tsimtech.com"
# TSIM_ACCOUNT="<TSIM_ACCOUNT>"
# TSIM_SECRET="<TSIM_SECRET>"
