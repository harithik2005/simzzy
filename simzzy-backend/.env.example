# Simzzy database — Supabase connection (copy to .env and fill in)
# URL-encode reserved characters in the password (e.g. % -> %25, + -> %2B, @ -> %40)

DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# ── tSIM (TSim Tech) eSIM supplier — Phase 4H.2A ───────────────────────────
# TSim Open API v1.0. Auth = per-request HMAC-SHA256 header signature
# (TSIM-ACCOUNT / TSIM-NONCE / TSIM-TIMESTAMP / TSIM-SIGN). No login/token.
TSIM_API_HOST="https://api.tsimtech.com"   # base URL
TSIM_ACCOUNT="<TSIM_ACCOUNT>"              # account allocated by TSim
TSIM_SECRET="<TSIM_SECRET>"                # HMAC secret (TSIM-SIGN key)
# Static-IP egress proxy (QuotaGuard Static / Fixie) so tSIM sees a fixed IP to
# whitelist (Vercel egress is dynamic). Format: http://user:pass@host:port
# Also auto-detected from QUOTAGUARDSTATIC_URL or FIXIE_URL if those are set.
# TSIM_PROXY_URL="http://user:pass@proxy-host:port"
# Phase 4H.2B fulfilment switch. "true" = a successful payment triggers a REAL,
# BILLABLE tSIM eSIM purchase + QR. Leave unset/false until the IP allowlist is
# confirmed and you've tested with a $0 plan — otherwise checkout uses the
# dummy fulfilment (no provider call, no real QR).
# TSIM_FULFILMENT_ENABLED="false"
